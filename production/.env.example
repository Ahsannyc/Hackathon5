# CloudFlow Customer Success AI Employee - Environment Configuration
# Copy this file to .env and fill in your actual values for development
# NEVER commit .env to version control (only .env.example)

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_PORT=8000
API_WORKERS=4
API_HOST=0.0.0.0

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=postgresql://cloudflow:password@localhost:5432/cloudflow_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_ECHO=false

# ============================================================================
# REDIS CACHE CONFIGURATION
# ============================================================================
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600
CACHE_BACKEND=redis

# ============================================================================
# KAFKA CONFIGURATION
# ============================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=cloudflow-agents
KAFKA_TOPIC_MESSAGES=customer-messages
KAFKA_TOPIC_ESCALATIONS=escalations
KAFKA_TOPIC_RESPONSES=customer-responses

# ============================================================================
# COHERE AI CONFIGURATION (for OpenAI Agents SDK)
# ============================================================================
COHERE_KEY=your-cohere-api-key-here
COHERE_MODEL=command-r-plus
DEBUG=false

# ============================================================================
# GMAIL INTEGRATION
# ============================================================================
GMAIL_ENABLED=true
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REDIRECT_URI=http://localhost:8000/api/gmail/callback
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.modify

# ============================================================================
# WHATSAPP BUSINESS API (via Twilio)
# ============================================================================
WHATSAPP_ENABLED=true
WHATSAPP_BUSINESS_API_URL=https://graph.instagram.com/v18.0
WHATSAPP_BUSINESS_PHONE_ID=your-phone-number-id
WHATSAPP_BUSINESS_TOKEN=your-whatsapp-business-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-verify-token
WHATSAPP_WEBHOOK_ENDPOINT=/api/whatsapp/webhook

# ============================================================================
# TWILIO CONFIGURATION (for WhatsApp via Twilio)
# ============================================================================
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_NUMBER=+1234567890

# ============================================================================
# WEB FORM CONFIGURATION
# ============================================================================
WEBFORM_ENABLED=true
WEBFORM_ENDPOINT=/api/form/submit
WEBFORM_MAX_FILE_SIZE=10485760

# ============================================================================
# SENTRY ERROR TRACKING
# ============================================================================
SENTRY_DSN=your-sentry-dsn-here
SENTRY_ENABLED=true
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================================================
# PROMETHEUS MONITORING
# ============================================================================
PROMETHEUS_PORT=9090
PROMETHEUS_ENABLED=true
METRICS_PORT=9091

# ============================================================================
# GRAFANA CONFIGURATION
# ============================================================================
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/var/log/cloudflow/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_ENABLED=true

# ============================================================================
# CELERY TASK QUEUE
# ============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_RESULT_EXPIRES=3600
CELERY_TIMEZONE=UTC

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_SECRET_KEY=your-jwt-secret-key-here
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_SENTIMENT_ML=false
ENABLE_ESCALATION_ML=false
ENABLE_VECTOR_SEARCH=false
ENABLE_KAFKA_STREAMING=true

# ============================================================================
# OBSERVABILITY
# ============================================================================
TRACING_ENABLED=true
METRICS_ENABLED=true
HEALTH_CHECK_ENABLED=true

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================
AUTO_RELOAD=true
RELOAD_DIRS=src,production
RELOAD_DELAY=0.25

